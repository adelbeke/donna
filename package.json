{
  "name": "donna",
  "private": true,
  "version": "1.12.0",
  "type": "module",
  "description": "Self-hostable GitHub PR dashboard — filter, prioritise, and track review status across all your repositories",
  "license": "MIT",
  "author": "Arthur Delbeke",
  "homepage": "https://github.com/adelbeke/donna#readme",
  "bugs": {
    "url": "https://github.com/adelbeke/donna/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adelbeke/donna.git"
  },
  "keywords": [
    "github",
    "pull-requests",
    "dashboard",
    "react",
    "typescript",
    "code-review"
  ],
  "main": "out/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "tsc -b && vite build",
    "build:electron": "electron-vite build && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "electron-updater": "^6.6.2",
    "graphql-request": "^7.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "electron-vite": {
      "vite": "$vite"
    },
    "graphql-request": {
      "graphql": "$graphql"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "graphql": "^17.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  }
}
